# BambooHR Integration
# These are only used server-side (serverless functions)
BAMBOOHR_API_KEY=your_bamboohr_api_key_here
BAMBOOHR_SUBDOMAIN=your_company_subdomain

# Hubstaff Integration
# No server-side env vars needed — the user's refresh token and org ID are
# entered in Settings → Connectors and stored in localStorage by the app.

# Email — Resend (preferred)
RESEND_API_KEY=your_resend_api_key

# Email — SMTP fallback (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=payroll@yourcompany.com
SMTP_FROM_NAME=Spectra Payroll

# App config
VITE_APP_NAME=Spectra Payroll
